# Copy to `.env` (or export these in your shell) before running locally.
# `.env` is git-ignored.

# Active CLI profile created with `databricks auth login --profile <name>`.
DATABRICKS_CONFIG_PROFILE=<your-profile>

# SQL Warehouse used for every query the app issues. Find it under
# SQL Warehouses > (warehouse) > Connection details > HTTP Path.
DATABRICKS_WAREHOUSE_ID=<your-warehouse-id>

# --- Optional overrides (defaults match the reference Eli Lilly demo) ------
# APP_CATALOG=eli_lilly_demo
# APP_SILVER_SCHEMA=silver_claims
# APP_GOLD_SCHEMA=gold_claims
# APP_SCHEMA=app_data
# APP_DASHBOARD_ID=<your-published-dashboard-id>
# APP_DASHBOARD_NAME=Population Health Executive Dashboard
