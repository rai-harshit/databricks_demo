{
  "datasets": [
    {
      "name": "patient_summary",
      "displayName": "Patient Summary",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  patient_summary"
      ],
      "columns": [
        {
          "displayName": "Age Group",
          "description": "Patient age cohorts for demographic analysis",
          "expression": "CASE WHEN `age` < 18 THEN '0-17' WHEN `age` < 35 THEN '18-34' WHEN `age` < 50 THEN '35-49' WHEN `age` < 65 THEN '50-64' ELSE '65+' END"
        }
      ],
      "catalog": "eli_lilly_demo",
      "schema": "gold_claims"
    },
    {
      "name": "diagnosis",
      "displayName": "Diagnosis Data",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  diagnosis"
      ],
      "catalog": "eli_lilly_demo",
      "schema": "silver_claims"
    },
    {
      "name": "claims_analytics",
      "displayName": "Claims Analytics",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  claims_analytics"
      ],
      "columns": [
        {
          "displayName": "Year-Month",
          "description": "Year-Month string for time series visualization",
          "expression": "CONCAT(CAST(`service_year` AS STRING), '-', LPAD(CAST(`service_month` AS STRING), 2, '0'))"
        },
        {
          "displayName": "Discount Percentage",
          "description": "Percentage discount between billed charges and allowed amounts",
          "expression": "100.0 * (1 - `total_allowed` / NULLIF(`total_charges`, 0))"
        }
      ],
      "catalog": "eli_lilly_demo",
      "schema": "gold_claims"
    }
  ],
